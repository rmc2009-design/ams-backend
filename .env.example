# ── Database ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Whoop ─────────────────────────────────────────────
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Per-athlete tokens are stored in the DB after OAuth flow

# ── Catapult ──────────────────────────────────────────
CATAPULT_API_URL=https://openfield.catapultsports.com/api/v6
CATAPULT_API_KEY=

# ── Polar ─────────────────────────────────────────────
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
# Per-athlete tokens stored in DB after OAuth

# ── Garmin ────────────────────────────────────────────
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# ── Vald ──────────────────────────────────────────────
VALD_API_URL=https://api.valdperformance.com
VALD_API_KEY=

# ── Hawkin Dynamics ───────────────────────────────────
HAWKIN_API_URL=https://api.hawkindynamics.com/api/v1
HAWKIN_TOKEN=

# ── Alerts ────────────────────────────────────────────
ALERT_WEBHOOK_URL=        # Slack / Teams webhook (optional)
ALERT_EMAIL=coach@team.com

# ── Sync schedule (cron syntax) ───────────────────────
SYNC_CRON="0 */6 * * *"         # every 6 hours
WEEKLY_REPORT_CRON="0 6 * * 1"  # Mondays at 6am
